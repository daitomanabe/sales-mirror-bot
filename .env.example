# Email (IMAP - incoming)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-password

# Email (SMTP - outgoing)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# OpenAI
OPENAI_API_KEY=sk-...

# Bot identity
BOT_DISPLAY_NAME=真鍋 大度
BOT_COMPANY_NAME=株式会社mmmm
BOT_EMAIL=your-email@example.com
BOT_TITLE=代表取締役

# Database
DATABASE_PATH=data/conversations.db

# Polling
POLL_INTERVAL_SECONDS=60

# Logging
LOG_LEVEL=INFO

# Dry-run mode (true = log responses without sending emails)
DRY_RUN=false

# Max simultaneous conversations
MAX_ACTIVE_CONVERSATIONS=50

# Dashboard sync (Cloudflare Workers)
DASHBOARD_URL=https://sales-mirror-dashboard.your-subdomain.workers.dev
DASHBOARD_API_TOKEN=your-secret-token
DASHBOARD_SYNC_INTERVAL=300
